# Example Blogmore Configuration File
# Copy this to blogmore.yaml or blogmore.yml to use

# Required: Directory containing your markdown posts
content_dir: posts

# Optional: Output directory for generated site (default: output)
output: output

# Optional: Custom templates directory (default: uses bundled templates)
# templates: my-templates

# Optional: Site title (default: "My Blog")
site_title: "My Blog"

# Optional: Site subtitle (optional)
# site_subtitle: "A subtitle for my blog"

# Optional: Default site description used in metadata for pages that have no
# description of their own (e.g. index, archive, tag, and category pages)
# site_description: "A blog about interesting things"

# Optional: Default keywords used in metadata for pages that have no keywords of
# their own (e.g. index, archive, tag, and category pages). Can be a
# comma-separated string or a YAML list. Individual posts use their tags as
# keywords, so site_keywords only applies when no post-specific keywords are
# available.
# site_keywords: "blog, technology, programming"
# site_keywords:
#   - blog
#   - technology
#   - programming

# Optional: Base URL of your site (used for RSS feeds and canonical URLs)
site_url: "https://example.com"

# Optional: Include posts marked as drafts (default: false)
include_drafts: false

# Optional: Remove the output directory before generating the site (default: false)
clean_first: false

# Optional: Maximum number of posts in RSS/Atom feeds (default: 20)
posts_per_feed: 20

# Optional: Default author name for posts without author in frontmatter
# default_author: "Your Name"

# Optional: Icon generation
# Specify a source image in the extras/ directory to generate favicon.ico
# and Apple touch icons. Should be a square image, ideally 1024x1024 or larger.
# icon_source: "icon.png"

# Optional: Enable client-side search (default: false)
# Generates a search index and a /search.html page when set to true.
# with_search: false

# Optional: Generate an XML sitemap (default: false)
# Requires site_url to be set for absolute URLs in the sitemap.
# with_sitemap: false

# Optional: Additional root-relative paths to include in the sitemap (default: none)
# These are appended to the auto-discovered generated HTML pages when building
# the sitemap. Each path should be root-relative (starting with "/"). The paths
# are resolved against site_url. Requires with_sitemap: true to have any effect.
# sitemap_extras:
#   - /some/path/
#   - /some/file.html

# Optional: Generate a blog statistics page (default: false)
# Generates a /stats.html page with posting patterns, word counts,
# reading times, link counts and more. A Stats link is added to the
# navigation bar automatically.
# with_stats: false

# Optional: Generate a calendar view of all posts (default: false)
# Generates a calendar.html page showing the full history of the blog as a
# reverse-chronological year calendar. Days with posts link to the daily
# archive, months link to the monthly archive, and years link to the yearly
# archive. A Calendar link is added to the navigation bar automatically.
# with_calendar: false

# Optional: Use forward (oldest-to-newest) ordering in the calendar (default: false)
# When true, the calendar runs in natural chronological order — oldest year at
# the top, oldest month first within each year, and day numbers increasing left
# to right (Monday first). When false (the default), everything is reversed so
# the most recent content appears first. Configuration file only.
# Only used when with_calendar is true.
# forward_calendar: false

# Optional: Show estimated reading time on posts (default: false)
# Displays the approximate time to read each post based on the configured WPM.
# with_read_time: false

# Optional: Words per minute used when calculating estimated reading time (default: 200)
# Must be a positive integer. Configuration file only.
# read_time_wpm: 200

# Optional: Show "References & mentions" section on individual post pages (default: false)
# When enabled, BlogMore scans all post content for internal links and shows a
# "References & mentions" section on each linked-to post page, listing which
# posts link to it along with a short plain-text context snippet.
# Only links in posts are considered; links in static pages are excluded.
# Configuration file only.
# with_backlinks: false

# Optional: Show "Generated with BlogMore" footer line (default: true)
# Set to false to hide the footer attribution line.
# with_advert: true

# Optional: Custom post URL path format (default: "{year}/{month}/{day}/{slug}.html")
# Available placeholders: {year}, {month}, {day}, {hour}, {minute}, {second},
# {category}, {author}, {slug}. The {slug} placeholder is required.
# post_path: "{year}/{month}/{day}/{slug}.html"

# Optional: Custom page URL path format (default: "{slug}.html")
# The only available placeholder is {slug}, which is required.
# page_path: "{slug}.html"

# Optional: Output path template for the first page of any paginated listing
# (main index, year/month/day archives, tag pages, category pages).
# The path is always appended to the end of the section base path being
# generated. The {page} placeholder is available but not required.
# Configuration file only.
# page_1_path: "index.html"

# Optional: Output path template for pages 2 and above of any paginated
# listing. The {page} placeholder is required and is substituted with the
# 1-based page number. Configuration file only.
# page_n_path: "page/{page}.html"

# Optional: Output path for the search page (default: "search.html")
# Controls where the search page is generated, relative to the output
# directory. The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page.
# Configuration file only.
# search_path: "search.html"

# Optional: Path for the archive page relative to the output directory
# (default: archive.html). The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page. Leading slashes are
# stripped so both archive.html and /archive.html produce the same result.
# Configuration file only.
# archive_path: "archive.html"

# Optional: Path for the tags overview page relative to the output directory
# (default: tags.html). The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page. Leading slashes are
# stripped so both tags.html and /tags.html produce the same result.
# Configuration file only.
# tags_path: "tags.html"

# Optional: Path for the categories overview page relative to the output directory
# (default: categories.html). The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page. Leading slashes are
# stripped so both categories.html and /categories.html produce the same result.
# Configuration file only.
# categories_path: "categories.html"

# Optional: Path for the statistics page relative to the output directory
# (default: stats.html). The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page. Leading slashes are
# stripped so both stats.html and /stats.html produce the same result.
# Only used when with_stats is true. Configuration file only.
# stats_path: "stats.html"

# Optional: Path for the calendar page relative to the output directory
# (default: calendar.html). The full directory path is created automatically.
# When clean_urls is enabled and the path ends in index.html, the
# index.html portion is omitted in links to the page. Leading slashes are
# stripped so both calendar.html and /calendar.html produce the same result.
# Only used when with_calendar is true. Configuration file only.
# calendar_path: "calendar.html"

# Optional: Generate clean URLs for posts and pages (default: false)
# When enabled, posts and pages whose URL ends with /index.html will use the
# shorter trailing-slash form instead (e.g. /pages/about/ instead of
# /pages/about/index.html). This also applies to paginated listing pages when
# page_1_path or page_n_path produces a path ending in index.html.
# Configuration file only.
# clean_urls: false

# Optional: Extra tags to inject into <head> on every generated page.
# Useful for adding custom link, meta, or other head tags without overriding
# templates. Each entry is a tag name mapped to a dict of its attributes.
# All attribute values are always emitted as double-quoted strings.
# Configuration file only. For extensive <head> customisation, use template
# overrides instead.
# head:
#   - link:
#       rel: author
#       href: /humans.txt
#   - meta:
#       name: theme-color
#       content: "#ffffff"
#   - link:
#       rel: human-json
#       href: /human.json

# Styling options

# Optional: Minify the CSS, writing it as styles.min.css (default: false)
# minify_css: false

# Optional: Minify the JavaScript, writing it as theme.min.js (default: false)
# If search is enabled, search.js is also minified as search.min.js.
# minify_js: false

# Optional: Minify all generated HTML output (default: false)
# minify_html: false

# Optional: Pygments style for syntax highlighting in light mode.
# See https://pygments.org/styles/ for all available styles.
# Configuration file only. Default: "xcode".
# light_mode_code_style: xcode

# Optional: Pygments style for syntax highlighting in dark mode.
# See https://pygments.org/styles/ for all available styles.
# Configuration file only. Default: "github-dark".
# dark_mode_code_style: github-dark

# Optional: Additional stylesheets to include (can be URLs or relative paths)
# extra_stylesheets:
#   - https://example.com/custom.css
#   - /assets/extra.css

# Optional: Site logo displayed in the sidebar (requires sidebar configuration)
# site_logo: /images/logo.png

# Optional: Control which pages appear in the sidebar and in what order.
# By default all pages from the pages/ directory are listed. When this list is
# set, only pages whose slug matches an entry are linked in the sidebar, in the
# order given here. Pages not listed are still generated but have no sidebar link.
# Configuration file only.
# pages:
#   - about
#   - my-tools
#   - colophon

# Optional: Links section in sidebar
# links:
#   - title: About
#     url: /about.html
#   - title: GitHub
#     url: https://github.com/username
#   - title: Contact
#     url: /contact.html

# Optional: Custom title for the links section in sidebar (default: "Links")
# links_title: "Links"

# Optional: Social media links in sidebar (displayed as Font Awesome brand icons)
# socials:
#   - site: mastodon
#     url: https://fosstodon.org/@username
#   - site: github
#     url: https://github.com/username
#   - site: lastfm
#     url: https://www.last.fm/user/username

# Optional: Custom title for the socials section in sidebar (default: "Social")
# socials_title: "Social"

# Serve-specific options (only used with 'blogmore serve' command)

# Optional: Port for local server (default: 8000)
port: 8000

# Optional: Disable file watching (default: false)
no_watch: false

# Publish-specific options (only used with 'blogmore publish' command)

# Optional: Git branch to publish to (default: gh-pages)
# branch: gh-pages

# Optional: Git remote to push to (default: origin)
# remote: origin
